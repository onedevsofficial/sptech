# ─────────────────────────────────────────────────────────────────────────
# Public site URL — used for canonical, sitemap, OG image absolute paths
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sptechweb.site

# ─────────────────────────────────────────────────────────────────────────
# Meta (Facebook/Instagram) Pixel — sitewide. Defaults to the production
# pixel `324995140034064` if unset. Override here per-environment (e.g. a
# separate test pixel for staging).
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=324995140034064

# ─────────────────────────────────────────────────────────────────────────
# Microsoft Clarity — session recording, heatmaps, click maps. Sitewide.
# Defaults to project `wiskih61v0` if unset. Override here per-environment
# (e.g. a separate Clarity project for staging).
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLARITY_ID=wiskih61v0

# ─────────────────────────────────────────────────────────────────────────
# Google Analytics 4 (gtag.js) — sitewide. Defaults to property
# `G-MD5CKDFKQR` if unset. Override here for a staging property.
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-MD5CKDFKQR

# ─────────────────────────────────────────────────────────────────────────
# Captcha HMAC secret — sign / verify the math-captcha tokens
# Generate one with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────
CAPTCHA_SECRET=replace-with-a-long-random-string

# ─────────────────────────────────────────────────────────────────────────
# Email delivery — choose ONE option below
# ─────────────────────────────────────────────────────────────────────────

# OPTION A (EASIEST — no DNS): Web3Forms  —  web3forms.com
# 1. Go to web3forms.com → "Get Access Key"
# 2. Enter the email where you want submissions delivered (info@sptechweb.site)
# 3. Confirm via the verification email Web3Forms sends you
# 4. Copy the access key (looks like: 1a2b3c4d-5e6f-7890-...) and paste below
# Free tier: 250 submissions/month. Takes priority over Resend / SMTP if set.
WEB3FORMS_KEY=

# OPTION B (Cleaner branding, needs DNS): Resend  —  resend.com
# 1. Sign up (free tier: 3,000 emails/month, 100/day)
# 2. Add & verify the domain `sptechweb.site` (DNS records — takes ~5 min)
# 3. Create an API key, paste below
# 4. CONTACT_FROM must be on the verified domain (e.g. info@sptechweb.site)
RESEND_API_KEY=

# OPTION C (FALLBACK): SMTP via your domain mailbox or any provider
# (Brevo, Mailgun, SendGrid, Hostinger, Zoho, etc.)
# Only used if neither WEB3FORMS_KEY nor RESEND_API_KEY is set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Inbox the form delivers to (comma-separated for multiple recipients)
CONTACT_TO=info@sptechweb.site

# Sender shown in the inbox — must be on a verified domain
CONTACT_FROM="SPTech Website <info@sptechweb.site>"
